{
  "include": ["lib"],
  "compilerOptions": {
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "exactOptionalPropertyTypes": true,
    "module": "node20",
    "outDir": "types",
    "rootDir": "lib",
    "declarationMap": true,
    "target": "es2020",
    "types": ["node"],
    "verbatimModuleSyntax": true
  }
}
